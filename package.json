{
  "name": "etrpc",
  "version": "0.1.0",
  "description": "Type-safe RPC for Electron. Queries, mutations, and streaming subscriptions with Zod validation.",
  "author": "David Del Val",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./main": {
      "types": "./dist/main/index.d.ts",
      "import": "./dist/main/index.js",
      "require": "./dist/main/index.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    },
    "./preload": {
      "types": "./dist/preload/index.d.cts",
      "require": "./dist/preload/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "main": ["dist/main/index.d.ts"],
      "renderer": ["dist/renderer/index.d.ts"],
      "preload": ["./dist/preload/index.d.cts"],
      "react": ["dist/react/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "electron": ">=22.0.0",
    "react": ">=18.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.0.0",
    "jsdom": "^28.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0",
    "zod": "^4.3.6"
  }
}
